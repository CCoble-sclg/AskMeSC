{
  "name": "askmesc-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create askmesc-db",
    "db:migrate": "wrangler d1 execute askmesc-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute askmesc-db --local --file=./migrations/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "hono": "^4.6.14"
  }
}

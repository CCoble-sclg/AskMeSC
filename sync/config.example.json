{
  "cloudflare": {
    "apiUrl": "https://your-api.workers.dev",
    "syncApiKey": "YOUR_SYNC_API_KEY",
    "accountId": "YOUR_CLOUDFLARE_ACCOUNT_ID"
  },
  "neon": {
    "enabled": true,
    "connectionString": "postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
  },
  "databases": [
    {
      "name": "MyDatabase",
      "enabled": true,
      "sqlServer": {
        "server": "YOUR_SQL_SERVER",
        "database": "YOUR_DATABASE",
        "integratedSecurity": true,
        "username": "",
        "password": ""
      },
      "discovery": {
        "excludeSchemas": ["sys", "INFORMATION_SCHEMA"],
        "excludeTables": [],
        "includeSchemas": [],
        "includeTables": [],
        "fullSyncTables": ["Employees", "Vendors", "Departments"],
        "dateFilterYears": 3,
        "dateColumnNames": ["CreatedDate", "ModifiedDate", "EntryDate", "DateCreated", "DateModified"]
      },
      "sanitization": {
        "rules": [
          { "columnPattern": "SSN", "action": "skip" },
          { "columnPattern": "Password", "action": "skip" }
        ],
        "maskPatterns": [
          { "columnPattern": "Email", "action": "mask_email" },
          { "columnPattern": "Phone", "action": "mask_phone" }
        ]
      },
      "embedding": {
        "textColumnPatterns": ["Description", "Notes", "Comments", "Name", "Title", "Address"],
        "minTextLength": 20
      }
    }
  ],
  "r2": {
    "chunkSize": 10000,
    "compressJson": true,
    "parallelUploads": 4
  },
  "sync": {
    "batchSize": 500,
    "retryAttempts": 3,
    "retryDelayMs": 5000,
    "exportPath": "./export"
  },
  "logging": {
    "logPath": "./logs",
    "logLevel": "Info"
  }
}
